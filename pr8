.Database Triggers  Implement and test triggers to maintain data integrity in the database. 

create database trigger_db;
use trigger_db;
create table emp(empid int(20)Primary key,empname varchar(50),salary int(30));
insert into emp values(1,"Ram",50000),(2,"Gita",60000),(3,"Sham",55000);
select * from emp;

1. Trigger to Maintain Data Integrity: 

drop trigger if exists chk_salary;
-> delimiter //
 create trigger chk_salary
 -> before insert on emp
 -> for each row
 -> begin ->
 if NEW.salary <= 0 then
 -> signal sqlstate '45000'
 -> set message_text="Salary can not be negative and zero!";
 -> end if;
 -> end;
 -> // 
delimiter ;
insert into emp values(4,"Sita",0);

2.Trigger to Prevent Deleting Employees with High Salary /*Business Rule:Employees earning more than 50,000 cannot be deleted.*/ 

mysql>
DELIMITER //
CREATE TRIGGER high_salary
-> BEFORE DELETE ON emp
-> FOR EACH ROW
-> BEGIN
->     IF OLD.salary > 50000 THEN
->         SIGNAL SQLSTATE '45000'
->         SET MESSAGE_TEXT = 'Cannot delete employee with salary greater than 50000';
->     END IF;
-> END;
-> //
DELIMITER ;
delete from emp where salary=60000;

 3.Trigger to Automatically Log Employee Inserts (Audit Integrity)
 DROP TRIGGER IF EXISTS emp_insert;
 DELIMITER // 
 CREATE TRIGGER emp_insert
 -> AFTER INSERT ON emp
 -> FOR EACH ROW
 -> BEGIN
 ->     INSERT INTO emp2 (empid, action, action_date)
 ->     VALUES (NEW.empid, 'INSERT', NOW());
 -> END;
 -> //
 DELIMITER ;
 insert into emp values(4,"Radha",50000);
 select * from emp;
 select * from emp2;

4. Trigger to Automatically Set Default Salary
CREATE TRIGGER default_salary
-> BEFORE INSERT ON emp
-> FOR EACH ROW -> BEGIN
->     IF NEW.salary IS NULL THEN
->         SET NEW.salary = 30000;
->     END IF;
-> END;
-> //
DELIMITER ;
insert into emp values(7,"Raj",NULL);
select * from emp;

























